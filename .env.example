# =============================================================================
# GMI ServiceOS - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# Never commit .env.local to version control.

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://gmi_user:your_password@localhost:5432/gmi_serviceos?schema=public"

# =============================================================================
# NEXTAUTH / AUTH.JS
# =============================================================================
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# AZURE ACTIVE DIRECTORY (SSO)
# =============================================================================
AZURE_AD_CLIENT_ID="your-azure-app-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-app-client-secret"
AZURE_AD_TENANT_ID="your-azure-tenant-id"

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_MAX_TOKENS="2048"
OPENAI_TEMPERATURE="0.2"

# =============================================================================
# N8N AUTOMATION
# =============================================================================
N8N_WEBHOOK_BASE_URL="https://n8n.gmi.internal/webhook"
N8N_WEBHOOK_SECRET="your-n8n-webhook-secret"
N8N_API_KEY="your-n8n-api-key"
N8N_BASE_URL="https://n8n.gmi.internal"

# =============================================================================
# CONNECTWISE MANAGE
# =============================================================================
CW_BASE_URL="https://na.myconnectwise.net/v4_6_release/apis/3.0"
CW_COMPANY_ID="your_cw_company_id"
CW_PUBLIC_KEY="your-cw-public-key"
CW_PRIVATE_KEY="your-cw-private-key"
CW_CLIENT_ID="your-cw-client-id"
CW_BOARD_ID="1"

# =============================================================================
# SERVICENOW
# =============================================================================
SNOW_INSTANCE_URL="https://your-instance.service-now.com"
SNOW_USERNAME="your-snow-username"
SNOW_PASSWORD="your-snow-password"
SNOW_CLIENT_ID="your-snow-oauth-client-id"
SNOW_CLIENT_SECRET="your-snow-oauth-client-secret"

# =============================================================================
# APPLICATION
# =============================================================================
APP_URL="http://localhost:3000"
APP_NAME="GMI ServiceOS"
APP_ENV="development"
APP_LOG_LEVEL="debug"

# =============================================================================
# SMTP / EMAIL
# =============================================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="notifications@gmi.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_NAME="GMI ServiceOS"
SMTP_FROM_ADDRESS="noreply@gmi.com"

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_TRIAGE="true"
FEATURE_AUTOMATION="true"
FEATURE_KNOWLEDGE_BASE="true"
FEATURE_PORTAL="true"
FEATURE_APPROVALS="true"
