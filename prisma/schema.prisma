// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum TicketStatus {
  NEW
  AI_TRIAGE
  AWAITING_USER
  AWAITING_APPROVAL
  AUTOMATION_RUNNING
  ASSIGNED
  IN_PROGRESS
  WAITING_VENDOR
  RESOLVED
  CLOSED
  REOPENED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum UserRole {
  ADMIN
  TECH
  MANAGER
  CUSTOMER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  RETIRED
  LOST
  IN_REPAIR
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  CHURNED
}

enum CompanyType {
  MANAGED
  PROJECT
  INTERNAL
  PARTNER
}

// =============================================================================
// MODELS
// =============================================================================

model Company {
  id          String        @id @default(cuid())
  name        String
  shortName   String?
  domain      String?
  type        CompanyType   @default(MANAGED)
  status      CompanyStatus @default(ACTIVE)
  slaId       String?
  sla         SLA?          @relation(fields: [slaId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tickets     Ticket[]
  contacts    Contact[]
  assets      Asset[]
  users       User[]

  @@map("companies")
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  title       String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets     Ticket[]
  assets      Asset[]

  @@map("contacts")
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  emailVerified DateTime?
  image       String?
  role        UserRole @default(TECH)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  assignedTickets Ticket[]       @relation("AssignedTech")
  comments        Comment[]
  approvalRequests Approval[]    @relation("ApprovalRequester")
  approvalResponses Approval[]   @relation("Approver")
  auditLogs       AuditLog[]
  notifications   Notification[]
  knowledgeArticles KnowledgeArticle[]
  teamMemberships TeamMember[]
  attachments     Attachment[]

  @@map("users")
}

// NextAuth adapter models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Board {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets     Ticket[]
  categories  Category[]
  catalogItems ServiceCatalogItem[]

  @@map("boards")
}

model Category {
  id            String   @id @default(cuid())
  name          String
  boardId       String
  board         Board    @relation(fields: [boardId], references: [id])
  subcategories String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tickets Ticket[]

  @@map("categories")
}

model SLA {
  id              String   @id @default(cuid())
  name            String
  responseMinutes Int
  resolveMinutes  Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  companies Company[]
  tickets   Ticket[]

  @@map("slas")
}

model Ticket {
  id                   String       @id @default(cuid())
  ticketNumber         Int          @unique @default(autoincrement())
  title                String
  description          String       @db.Text
  status               TicketStatus @default(NEW)
  priority             Priority     @default(MEDIUM)
  impact               String?
  urgency              String?
  boardId              String?
  board                Board?       @relation(fields: [boardId], references: [id])
  categoryId           String?
  category             Category?    @relation(fields: [categoryId], references: [id])
  subcategory          String?
  source               String?      // email, portal, phone, api, automation
  companyId            String?
  company              Company?     @relation(fields: [companyId], references: [id])
  contactId            String?
  contact              Contact?     @relation(fields: [contactId], references: [id])
  assignedUserId       String?
  assignedUser         User?        @relation("AssignedTech", fields: [assignedUserId], references: [id])
  assignedTeamId       String?
  assignedTeam         Team?        @relation(fields: [assignedTeamId], references: [id])
  slaId                String?
  sla                  SLA?         @relation(fields: [slaId], references: [id])
  dueAt                DateTime?
  aiConfidenceScore    Float?
  aiRecommendedAction  String?      @db.Text
  resolvedAt           DateTime?
  closedAt             DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  comments       Comment[]
  notes          Note[]
  attachments    Attachment[]
  auditLogs      AuditLog[]
  approvals      Approval[]
  automationRuns AutomationRun[]
  aiDecisionLogs AIDecisionLog[]
  linkedAssets   TicketAsset[]
  notifications  Notification[]

  @@index([status])
  @@index([priority])
  @@index([companyId])
  @@index([assignedUserId])
  @@index([boardId])
  @@index([createdAt])
  @@map("tickets")
}

model Comment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("comments")
}

model Note {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

model Attachment {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  filename     String
  url          String
  size         Int
  mimeType     String
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("attachments")
}

model Approval {
  id            String         @id @default(cuid())
  ticketId      String
  ticket        Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User           @relation("ApprovalRequester", fields: [requestedById], references: [id])
  approverId    String
  approver      User           @relation("Approver", fields: [approverId], references: [id])
  status        ApprovalStatus @default(PENDING)
  reason        String?        @db.Text
  requestedAt   DateTime       @default(now())
  respondedAt   DateTime?

  @@map("approvals")
}

model Asset {
  id           String      @id @default(cuid())
  name         String
  type         String
  serialNumber String?
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  contactId    String?
  contact      Contact?    @relation(fields: [contactId], references: [id])
  status       AssetStatus @default(ACTIVE)
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tickets TicketAsset[]

  @@map("assets")
}

model TicketAsset {
  ticketId  String
  assetId   String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([ticketId, assetId])
  @@map("ticket_assets")
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  category    String
  tags        String[]
  viewCount   Int      @default(0)
  isPublished Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("knowledge_articles")
}

model AutomationRun {
  id           String    @id @default(cuid())
  ticketId     String
  ticket       Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  runbookName  String
  status       String    // PENDING, RUNNING, SUCCESS, FAILED, CANCELLED
  output       String?   @db.Text
  webhookUrl   String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  @@map("automation_runs")
}

model AIDecisionLog {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  model      String
  prompt     String   @db.Text
  response   String   @db.Text
  confidence Float?
  action     String?
  createdAt  DateTime @default(now())

  @@map("ai_decision_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]
  tickets Ticket[]

  @@map("teams")
}

model TeamMember {
  teamId    String
  userId    String
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@id([teamId, userId])
  @@map("team_members")
}

model ServiceCatalogItem {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  category    String
  icon        String?
  formSchema  Json?
  boardId     String?
  board       Board?   @relation(fields: [boardId], references: [id])
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service_catalog_items")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}
